<Window x:Class="HDRSnip.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HDRSnip"
        Width="900"
        Height="640"
        MinWidth="520"
        MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Background="#FF1A1A1A"
        KeyDown="OnKeyDown">
  <DockPanel>
    <Border DockPanel.Dock="Top"
            Background="#FF222222"
            BorderBrush="#33FFFFFF"
            BorderThickness="0,0,0,1"
            Padding="12,10">
      <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
          <TextBlock Text="HDRSnip"
                     FontFamily="Segoe UI Semibold"
                     FontSize="15"
                     Foreground="White"
                     VerticalAlignment="Center"
                     Margin="0,0,16,0" />
          <TextBlock x:Name="HdrBadge"
                     Text="HDR → SDR"
                     FontSize="11"
                     Foreground="#FF1A1A1A"
                     Background="#FF4CC2FF"
                     Padding="8,3"
                     VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="Copy" Style="{StaticResource ActionBtn}" Click="OnCopy" Margin="0,0,8,0" />
          <Button Content="Save" Style="{StaticResource ActionBtn}" Click="OnSave" Margin="0,0,8,0" />
          <Button Content="Save As…" Style="{StaticResource ActionBtn}" Click="OnSaveAs" />
        </StackPanel>
      </DockPanel>
    </Border>
    <Border DockPanel.Dock="Bottom"
            Background="#FF222222"
            Padding="12,8">
      <TextBlock x:Name="StatusText"
                 Foreground="#FFAAAAAA"
                 FontSize="12"
                 FontFamily="Segoe UI" />
    </Border>
    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  Background="#FF121212">
      <Image x:Name="Preview"
             Stretch="None"
             HorizontalAlignment="Center"
             VerticalAlignment="Center"
             Margin="24" />
    </ScrollViewer>
  </DockPanel>
</Window>
