<Window x:Class="HDRSnip.Views.SnipToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HDRSnip"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        Background="Transparent"
        AllowsTransparency="True"
        KeyDown="OnKeyDown">
  <Border Background="#F01C1C1C"
          BorderBrush="#33FFFFFF"
          BorderThickness="1"
          CornerRadius="10"
          Padding="8">
    <StackPanel Orientation="Horizontal">
      <Button x:Name="BtnRectangle" Style="{StaticResource ToolBtn}" Click="OnRectangle" ToolTip="Rectangular snip">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="▢" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" />
          <TextBlock Text="Rectangular" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
      <Button x:Name="BtnWindow" Style="{StaticResource ToolBtn}" Click="OnWindow" ToolTip="Window snip (monitor under cursor)">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="🗔" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
          <TextBlock Text="Window" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
      <Button x:Name="BtnFull" Style="{StaticResource ToolBtn}" Click="OnFullScreen" ToolTip="Full screen (monitor under cursor)">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="⛶" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
          <TextBlock Text="Fullscreen" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
      <Rectangle Width="1" Fill="#44FFFFFF" Margin="6,4" />
      <Button Style="{StaticResource ToolBtn}" Click="OnClose" ToolTip="Close (Esc)">
        <TextBlock Text="✕" FontSize="14" />
      </Button>
    </StackPanel>
  </Border>
</Window>
