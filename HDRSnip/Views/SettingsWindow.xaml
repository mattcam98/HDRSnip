<Window x:Class="HDRSnip.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HDRSnip Settings"
        Width="480"
        Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#FF1A1A1A">
  <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
    <StackPanel>
      <TextBlock Text="HDRSnip" FontSize="20" FontFamily="Segoe UI Semibold" Foreground="White" Margin="0,0,0,4" />
      <TextBlock Text="HDR-aware snipping tool" Foreground="#FF888888" Margin="0,0,0,20" />

      <TextBlock Text="Save folder" Style="{StaticResource FieldLabel}" />
      <DockPanel Margin="0,0,0,14">
        <Button DockPanel.Dock="Right" Content="Browse…" Style="{StaticResource ActionBtn}" Click="OnBrowse" Margin="8,0,0,0" />
        <TextBox x:Name="SaveFolderBox" Style="{StaticResource FieldBox}" />
      </DockPanel>

      <TextBlock Text="Tone mapping" Style="{StaticResource FieldLabel}" />
      <ComboBox x:Name="ToneMapBox" Style="{StaticResource FieldCombo}" Margin="0,0,0,14">
        <ComboBoxItem Content="Windows / OBS (recommended)" Tag="Windows" />
        <ComboBoxItem Content="ACES filmic" Tag="Aces" />
        <ComboBoxItem Content="Reinhard" Tag="Reinhard" />
      </ComboBox>

      <TextBlock Text="SDR white (nits)" Style="{StaticResource FieldLabel}" />
      <DockPanel Margin="0,0,0,4">
        <TextBlock x:Name="NitsLabel" DockPanel.Dock="Right" Foreground="#FF4CC2FF" Width="48" TextAlignment="Right" VerticalAlignment="Center" />
        <Slider x:Name="NitsSlider" Minimum="160" Maximum="480" TickFrequency="10" IsSnapToTickEnabled="True"
                ValueChanged="OnNitsChanged" />
      </DockPanel>
      <TextBlock Text="Higher = darker screenshots. Try 200–280 if text still looks washed out."
                 Foreground="#FF777777" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,14" />

      <CheckBox x:Name="CopyCheck" Content="Copy to clipboard after capture" Style="{StaticResource FieldCheck}" />
      <CheckBox x:Name="EditorCheck" Content="Open editor after capture" Style="{StaticResource FieldCheck}" />
      <CheckBox x:Name="AutoSaveCheck" Content="Auto-save PNG on capture" Style="{StaticResource FieldCheck}" />
      <CheckBox x:Name="AutostartCheck" Content="Start with Windows" Style="{StaticResource FieldCheck}" Margin="0,0,0,18" />

      <TextBlock Text="Hotkeys" Style="{StaticResource FieldLabel}" />
      <TextBlock x:Name="HotkeyInfo" Foreground="#FFAAAAAA" FontSize="12" Margin="0,0,0,6" TextWrapping="Wrap" />
      <TextBlock Text="Change hotkeys by editing %LOCALAPPDATA%\HDRSnip\config.json (modifiers: Alt=1 Ctrl=2 Shift=4 Win=8)."
                 Foreground="#FF666666" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,20" />

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Cancel" Style="{StaticResource ActionBtn}" Click="OnCancel" Margin="0,0,8,0" />
        <Button Content="Save" Style="{StaticResource PrimaryBtn}" Click="OnSave" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Window>
