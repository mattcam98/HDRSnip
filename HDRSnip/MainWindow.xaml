<Window x:Class="HDRSnip.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="HDRSnip"
        Width="1"
        Height="1"
        WindowStyle="None"
        ShowInTaskbar="False"
        ShowActivated="False"
        Visibility="Hidden"
        Opacity="0">
  <tb:TaskbarIcon x:Name="Tray"
                  ToolTipText="HDRSnip — HDR snipping tool"
                  TrayMouseDoubleClick="OnTrayDoubleClick"
                  MenuActivation="RightClick">
    <tb:TaskbarIcon.ContextMenu>
      <ContextMenu>
        <MenuItem Header="New snip" Click="OnNewSnip" />
        <MenuItem Header="Fullscreen snip" Click="OnFullSnip" />
        <Separator />
        <MenuItem Header="Settings…" Click="OnSettings" />
        <Separator />
        <MenuItem Header="Exit" Click="OnExit" />
      </ContextMenu>
    </tb:TaskbarIcon.ContextMenu>
  </tb:TaskbarIcon>
</Window>
